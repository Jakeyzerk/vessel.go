# vessel.go - environment variables
# Copy this file: cp .env.example .env
# Never commit .env to a public repository

# Required - get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Who is allowed to speak to the vessel.
# Set both for the vessel to recognize you whether you message
# from your phone directly or from a linked device.
#
# VESSEL_USER_WA  - your WhatsApp number
#                   format: country code + number, no + or spaces
#                   example: 628123456789
#
# VESSEL_USER_JID - your internal WhatsApp JID
#                   this appears in the terminal the first time you run the vessel
#                   it may look different from your phone number - that is normal
#                   example: 168289787482341
#
VESSEL_USER_WA=your_whatsapp_number_here
VESSEL_USER_JID=your_whatsapp_jid_here

# Optional - only needed if you want voice note replies
# Get your key at https://www.minimaxi.com
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
